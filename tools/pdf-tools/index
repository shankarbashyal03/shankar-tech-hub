    <script>
        pdfjsLib.GlobalWorkerOptions.workerSrc='https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
        function applyTheme(t){document.body.classList.toggle('light-mode',t==='light')}
        applyTheme(localStorage.getItem('shankartech_theme')||'dark');
        window.addEventListener('storage',e=>{if(e.key==='shankartech_theme')applyTheme(e.newValue||'dark')});

        let pdfDoc=null,pdfBytes=null,currentPage=1,totalPages=0,zoomScale=1.5;
        let activeTool='select',elements=[],undoStack=[],redoStack=[];
        let selectedElement=null,drawStart=null,currentShape=null;
        let pendingImage=null,pendingSignature=null;
        let textStyles={fontFamily:'Arial',fontSize:16,color:'#000000',bold:false,italic:false,underline:false};
        let highlightColor='#FFFF00',highlightOpacity=0.4,selectedFile=null;

        function handleDragOver(e){e.preventDefault();document.getElementById('uploadCard').classList.add('drag-over')}
        function handleDragLeave(e){document.getElementById('uploadCard').classList.remove('drag-over')}
        function handleDrop(e){e.preventDefault();document.getElementById('uploadCard').classList.remove('drag-over');const f=e.dataTransfer.files[0];if(f&&f.type==='application/pdf')processFile(f);else showToast('Please drop a PDF file','error')}
        function handleFileSelect(e){const f=e.target.files[0];if(f)processFile(f)}
        function changeFile(){document.getElementById('fileLoaded').classList.remove('show');selectedFile=null;document.getElementById('fileInput').value=''}
        function processFile(file){selectedFile=file;document.getElementById('loadedFileName').textContent=file.name;document.getElementById('loadedFileMeta').textContent=formatSize(file.size)+' • Ready to edit';document.getElementById('fileLoaded').classList.add('show')}
        function formatSize(b){if(b<1024)return b+' B';if(b<1048576)return(b/1024).toFixed(1)+' KB';return(b/1048576).toFixed(2)+' MB'}

        async function openEditor(){
            if(!selectedFile)return;showProcessing('Loading PDF...');
            try{
                const ab=await selectedFile.arrayBuffer();pdfBytes=new Uint8Array(ab);
                pdfDoc=await pdfjsLib.getDocument({data:pdfBytes}).promise;totalPages=pdfDoc.numPages;currentPage=1;
                document.getElementById('landingPage').style.display='none';
                document.getElementById('editorFull').classList.add('show');
                await renderAllPages();renderThumbnails();updatePageNav();
                hideProcessing();showToast('PDF loaded! Ready to edit.');
            }catch(err){hideProcessing();showToast('Error loading PDF: '+err.message,'error')}
        }

        async function renderAllPages(){
            document.getElementById('centerP').innerHTML='';elements=[];
            for(let i=1;i<=totalPages;i++){
                const pc=document.createElement('div');pc.className='pg-container';pc.dataset.page=i;pc.id='page-'+i;
                const c=document.createElement('canvas');c.className='pdf-canvas';c.id='canvas-'+i;
                const o=document.createElement('div');o.className='overlay';o.id='overlay-'+i;o.dataset.page=i;
                pc.appendChild(c);pc.appendChild(o);document.getElementById('centerP').appendChild(pc);
                await renderPage(i);
                o.addEventListener('click',e=>handleOverlayClick(e,i));
                o.addEventListener('mousedown',e=>handleOverlayMouseDown(e,i));
                o.addEventListener('mousemove',e=>handleOverlayMouseMove(e,i));
                o.addEventListener('mouseup',e=>handleOverlayMouseUp(e,i));
            }
        }
        async function renderPage(pn){
            const page=await pdfDoc.getPage(pn);const vp=page.getViewport({scale:zoomScale});
            const c=document.getElementById('canvas-'+pn);c.width=vp.width;c.height=vp.height;
            await page.render({canvasContext:c.getContext('2d'),viewport:vp}).promise;
            document.getElementById('overlay-'+pn).style.width=vp.width+'px';
            document.getElementById('overlay-'+pn).style.height=vp.height+'px';
            document.getElementById('zoomDisplay').textContent=Math.round(zoomScale*100)+'%';
        }
        async function renderThumbnails(){
            const t=document.getElementById('thumbnails');t.innerHTML='';
            for(let i=1;i<=totalPages;i++){
                const page=await pdfDoc.getPage(i);const vp=page.getViewport({scale:0.2});
                const c=document.createElement('canvas');c.width=vp.width;c.height=vp.height;
                await page.render({canvasContext:c.getContext('2d'),viewport:vp}).promise;
                const d=document.createElement('div');d.className='pthumb'+(i===currentPage?' active':'');
                d.appendChild(c);const n=document.createElement('div');n.className='pnum';n.textContent='Pg '+i;
                d.appendChild(n);d.onclick=()=>scrollToPage(i);t.appendChild(d);
            }
        }
        function scrollToPage(pn){currentPage=pn;document.getElementById('page-'+pn).scrollIntoView({behavior:'smooth'});updatePageNav();updateThumbnails()}
        function updatePageNav(){document.getElementById('pageNav').textContent=currentPage+'/'+totalPages}
        function updateThumbnails(){document.querySelectorAll('.pthumb').forEach((t,i)=>{t.classList.toggle('active',i+1===currentPage)})}
        function zoomIn(){zoomScale=Math.min(zoomScale+0.25,4);refreshAll()}
        function zoomOut(){zoomScale=Math.max(zoomScale-0.25,0.5);refreshAll()}
        async function refreshAll(){for(let i=1;i<=totalPages;i++)await renderPage(i)}
        function nextPage(){if(currentPage<totalPages)scrollToPage(currentPage+1)}
        function prevPage(){if(currentPage>1)scrollToPage(currentPage-1)}

        document.querySelectorAll('.tbtn[data-tool]').forEach(b=>{b.addEventListener('click',()=>{
            const tool=b.dataset.tool;if(tool==='undo'){undo();return}if(tool==='redo'){redo();return}
            document.querySelectorAll('.tbtn[data-tool]').forEach(x=>x.classList.remove('active'));
            b.classList.add('active');activeTool=tool;updateRightPanel();
        })});

        function updateRightPanel(){
            document.getElementById('sideR').classList.add('show');
            const pt=document.getElementById('panelTitle'),pc=document.getElementById('panelContent');
            switch(activeTool){
                case'select':pt.textContent='Select Tool';pc.innerHTML='<p style="color:var(--text-secondary);font-size:0.78rem;">Click element to select.<br>Drag to move.<br>Press Delete to remove.</p>';break;
                case'text':pt.textContent='Add Text';pc.innerHTML='<div class="fg"><label>Font</label><select class="finput" onchange="textStyles.fontFamily=this.value"><option>Arial</option><option>Times New Roman</option><option>Courier New</option><option>Georgia</option><option>Verdana</option></select></div><div class="fg"><label>Size</label><input type="number" class="finput" value="16" min="6" max="200" onchange="textStyles.fontSize=parseInt(this.value)"></div><div class="fg"><label>Color</label><input type="color" value="#000000" onchange="textStyles.color=this.value"></div><div class="sbtns"><button class="sbtn" id="boldBtn" onclick="toggleBold()"><b>B</b></button><button class="sbtn" id="italicBtn" onclick="toggleItalic()"><i>I</i></button><button class="sbtn" id="underlineBtn" onclick="toggleUnderline()"><u>U</u></button></div><p style="color:var(--text-secondary);font-size:0.68rem;margin-top:6px;">💡 Click on PDF to add text</p>';break;
                case'image':pt.textContent='Insert Image';pc.innerHTML='<div class="fg"><label>Choose Image</label><input type="file" accept="image/*" class="finput" onchange="loadPendingImage(event)"></div><div id="imagePreview" style="text-align:center;margin-top:5px;"></div><p style="color:var(--text-secondary);font-size:0.68rem;margin-top:5px;">💡 Click on PDF to place</p>';break;
                case'highlight':pt.textContent='Highlight';pc.innerHTML='<div class="fg"><label>Color</label><div class="cswatches"><div class="cswatch selected" style="background:#FFFF00" onclick="selectHighlightColor(\'#FFFF00\',this)"></div><div class="cswatch" style="background:#90EE90" onclick="selectHighlightColor(\'#90EE90\',this)"></div><div class="cswatch" style="background:#FFB6C1" onclick="selectHighlightColor(\'#FFB6C1\',this)"></div><div class="cswatch" style="background:#ADD8E6" onclick="selectHighlightColor(\'#ADD8E6\',this)"></div><div class="cswatch" style="background:#FFD700" onclick="selectHighlightColor(\'#FFD700\',this)"></div></div></div><div class="fg"><label>Opacity: <span id="opacityVal">40%</span></label><input type="range" class="finput" min="10" max="80" value="40" oninput="highlightOpacity=this.value/100;document.getElementById(\'opacityVal\').textContent=this.value+\'%\'"></div><p style="color:var(--text-secondary);font-size:0.68rem;">💡 Click & drag to highlight</p>';break;
                case'whiteout':pt.textContent='Whiteout';pc.innerHTML='<p style="color:var(--text-secondary);font-size:0.78rem;">Click and drag to cover content with white rectangle.</p>';break;
                case'sign':pt.textContent='Signature';pc.innerHTML='<div class="stabs"><div class="stab active" onclick="switchSigTab(\'draw\',this)">Draw</div><div class="stab" onclick="switchSigTab(\'type\',this)">Type</div></div><div class="scontent active" id="sigDraw"><canvas class="sigcanvas" id="sigCanvas" width="210" height="85"></canvas><button class="bsm bsm-outline" onclick="clearSignature()">Clear</button><button class="bsm bsm-accent" onclick="placeSignature()">Place on PDF</button></div><div class="scontent" id="sigType"><input type="text" class="finput" id="sigText" placeholder="Type your name" style="margin-bottom:4px;"><select class="finput" id="sigFont" style="margin-bottom:4px;"><option value="\'Dancing Script\', cursive">Dancing Script</option><option value="\'Pacifico\', cursive">Pacifico</option><option value="\'Great Vibes\', cursive">Great Vibes</option></select><button class="bsm bsm-accent" onclick="placeTypedSignature()">Place on PDF</button></div>';initSigCanvas();break;
            }
        }

        function handleOverlayClick(e,pn){if(activeTool==='text')addTextElement(e,pn);else if(activeTool==='image'&&pendingImage)addImageElement(e,pn);else if(activeTool==='sign'&&pendingSignature)addSignatureElement(e,pn)}
        function handleOverlayMouseDown(e,pn){if(activeTool==='select')deselectElement();else if(['highlight','whiteout'].includes(activeTool)){const o=document.getElementById('overlay-'+pn);const r=o.getBoundingClientRect();drawStart={x:e.clientX-r.left,y:e.clientY-r.top};currentShape=document.createElement('div');currentShape.className='pdf-element';currentShape.style.cssText='position:absolute;left:'+drawStart.x+'px;top:'+drawStart.y+'px;width:0;height:0;background:'+(activeTool==='highlight'?highlightColor:'#FFFFFF')+';opacity:'+(activeTool==='highlight'?highlightOpacity:'1')+';pointer-events:none;';o.appendChild(currentShape)}}
        function handleOverlayMouseMove(e,pn){if(['highlight','whiteout'].includes(activeTool)&&drawStart&&currentShape){const o=document.getElementById('overlay-'+pn);const r=o.getBoundingClientRect();const cx=e.clientX-r.left,cy=e.clientY-r.top;currentShape.style.left=Math.min(drawStart.x,cx)+'px';currentShape.style.top=Math.min(drawStart.y,cy)+'px';currentShape.style.width=Math.abs(cx-drawStart.x)+'px';currentShape.style.height=Math.abs(cy-drawStart.y)+'px'}}
        function handleOverlayMouseUp(e,pn){if(['highlight','whiteout'].includes(activeTool)&&currentShape){if(parseInt(currentShape.style.width)>3||parseInt(currentShape.style.height)>3){pushUndo();elements.push({type:activeTool,page:pn,element:currentShape})}else currentShape.remove();currentShape=null;drawStart=null}}

        function addTextElement(e,pn){const o=document.getElementById('overlay-'+pn);const r=o.getBoundingClientRect();const div=document.createElement('div');div.className='pdf-element';div.contentEditable=true;div.style.cssText='position:absolute;left:'+(e.clientX-r.left)+'px;top:'+(e.clientY-r.top)+'px;font-family:'+textStyles.fontFamily+';font-size:'+textStyles.fontSize+'px;color:'+textStyles.color+';font-weight:'+(textStyles.bold?'bold':'normal')+';font-style:'+(textStyles.italic?'italic':'normal')+';text-decoration:'+(textStyles.underline?'underline':'none')+';min-width:40px;cursor:move;outline:1px dashed #3b82f6;padding:3px;';div.textContent='Text';div.addEventListener('mousedown',ev=>selectElement(ev,div));div.addEventListener('blur',()=>{div.style.outline='none';pushUndo()});o.appendChild(div);div.focus();pushUndo();elements.push({type:'text',page:pn,element:div})}
        function addImageElement(e,pn){const o=document.getElementById('overlay-'+pn);const r=o.getBoundingClientRect();const div=document.createElement('div');div.className='pdf-element';div.style.cssText='position:absolute;left:'+(e.clientX-r.left)+'px;top:'+(e.clientY-r.top)+'px;cursor:move;';const img=document.createElement('img');img.src=pendingImage;img.style.maxWidth='150px';img.style.maxHeight='150px';img.style.display='block';div.appendChild(img);div.addEventListener('mousedown',ev=>selectElement(ev,div));o.appendChild(div);pushUndo();elements.push({type:'image',page:pn,element:div,src:pendingImage});pendingImage=null;document.getElementById('imagePreview').innerHTML=''}
        function addSignatureElement(e,pn){const o=document.getElementById('overlay-'+pn);const r=o.getBoundingClientRect();const div=document.createElement('div');div.className='pdf-element';div.style.cssText='position:absolute;left:'+(e.clientX-r.left)+'px;top:'+(e.clientY-r.top)+'px;cursor:move;';const img=document.createElement('img');img.src=pendingSignature;img.style.maxWidth='130px';img.style.maxHeight='55px';div.appendChild(img);div.addEventListener('mousedown',ev=>selectElement(ev,div));o.appendChild(div);pushUndo();elements.push({type:'signature',page:pn,element:div,src:pendingSignature});pendingSignature=null}

        function selectElement(e,el){if(activeTool!=='select')return;e.stopPropagation();deselectElement();selectedElement=el;el.classList.add('selected')}
        function deselectElement(){if(selectedElement){selectedElement.classList.remove('selected');selectedElement=null}}

        function pushUndo(){undoStack.push(JSON.stringify(elements.map(el=>({type:el.type,page:el.page,html:el.element.outerHTML,src:el.src||null}))));if(undoStack.length>30)undoStack.shift();redoStack=[]}
        function undo(){if(!undoStack.length)return;redoStack.push(JSON.stringify(elements.map(el=>({type:el.type,page:el.page,html:el.element.outerHTML,src:el.src||null}))));restoreState(undoStack.pop())}
        function redo(){if(!redoStack.length)return;undoStack.push(JSON.stringify(elements.map(el=>({type:el.type,page:el.page,html:el.element.outerHTML,src:el.src||null}))));restoreState(redoStack.pop())}
        function restoreState(state){for(let i=1;i<=totalPages;i++)document.getElementById('overlay-'+i).querySelectorAll('.pdf-element').forEach(el=>el.remove());elements=[];JSON.parse(state).forEach(item=>{const o=document.getElementById('overlay-'+item.page);const div=document.createElement('div');div.innerHTML=item.html;const el=div.firstChild;o.appendChild(el);el.addEventListener('mousedown',ev=>selectElement(ev,el));if(item.type==='text'){el.contentEditable=true;el.addEventListener('blur',()=>{el.style.outline='none';pushUndo()})}elements.push({type:item.type,page:item.page,element:el,src:item.src||null})})}

        document.addEventListener('keydown',e=>{if(e.ctrlKey&&e.key==='z'){e.preventDefault();undo()}if(e.ctrlKey&&e.key==='y'){e.preventDefault();redo()}if(e.key==='Delete'&&selectedElement&&activeTool==='select'){selectedElement.remove();elements=elements.filter(el=>el.element!==selectedElement);selectedElement=null;pushUndo()}if(e.key==='Escape'){deselectElement();document.querySelectorAll('.tbtn[data-tool]').forEach(b=>b.classList.remove('active'));document.querySelector('.tbtn[data-tool="select"]').classList.add('active');activeTool='select';updateRightPanel()}});

        function loadPendingImage(e){const f=e.target.files[0];if(!f)return;const r=new FileReader();r.onload=ev=>{pendingImage=ev.target.result;document.getElementById('imagePreview').innerHTML='<img src="'+pendingImage+'" style="max-width:100%;max-height:60px;border-radius:6px;">';showToast('Image ready!')};r.readAsDataURL(f)}
        function selectHighlightColor(c,el){highlightColor=c;document.querySelectorAll('.cswatch').forEach(s=>s.classList.remove('selected'));el.classList.add('selected')}
        function initSigCanvas(){setTimeout(()=>{const c=document.getElementById('sigCanvas');if(!c)return;const ctx=c.getContext('2d');let d=false;c.onmousedown=e=>{d=true;ctx.beginPath();ctx.moveTo(e.offsetX,e.offsetY)};c.onmousemove=e=>{if(d){ctx.lineTo(e.offsetX,e.offsetY);ctx.stroke()}};c.onmouseup=()=>{d=false};c.onmouseleave=()=>{d=false}},100)}
        function clearSignature(){const c=document.getElementById('sigCanvas');if(c)c.getContext('2d').clearRect(0,0,c.width,c.height)}
        function placeSignature(){const c=document.getElementById('sigCanvas');if(c){pendingSignature=c.toDataURL('image/png');showToast('Signature ready!')}}
        function placeTypedSignature(){const t=document.getElementById('sigText').value;if(!t){showToast('Type your name','error');return}const f=document.getElementById('sigFont').value;const c=document.createElement('canvas');c.width=200;c.height=50;const ctx=c.getContext('2d');ctx.fillStyle='#000';ctx.font='24px '+f;ctx.textAlign='center';ctx.fillText(t,100,35);pendingSignature=c.toDataURL('image/png');showToast('Signature ready!')}
        function switchSigTab(tab,el){document.querySelectorAll('.stab').forEach(t=>t.classList.remove('active'));document.querySelectorAll('.scontent').forEach(c=>c.classList.remove('active'));el.classList.add('active');document.getElementById('sig'+tab.charAt(0).toUpperCase()+tab.slice(1)).classList.add('active')}
        function toggleBold(){textStyles.bold=!textStyles.bold;document.getElementById('boldBtn').classList.toggle('active-style',textStyles.bold)}
        function toggleItalic(){textStyles.italic=!textStyles.italic;document.getElementById('italicBtn').classList.toggle('active-style',textStyles.italic)}
        function toggleUnderline(){textStyles.underline=!textStyles.underline;document.getElementById('underlineBtn').classList.toggle('active-style',textStyles.underline)}

        async function savePDF(){
            showProcessing('Saving PDF...');
            try{
                const pdfLibDoc=await PDFLib.PDFDocument.load(pdfBytes);const pages=pdfLibDoc.getPages();
                const font=await pdfLibDoc.embedFont(PDFLib.StandardFonts.Helvetica);
                for(const el of elements){
                    const page=pages[el.page-1];const c=document.getElementById('canvas-'+el.page);
                    const{width:pw,height:ph}=page.getSize();const sr=pw/c.width;
                    const px=(parseInt(el.element.style.left)||0)*sr;
                    const py=ph-((parseInt(el.element.style.top)||0)*sr)-16*sr;
                    if(el.type==='text')page.drawText(el.element.textContent||'Text',{x:px,y:py,size:textStyles.fontSize*sr,font,color:PDFLib.rgb(0,0,0)});
                    else if(el.type==='image'||el.type==='signature'){if(el.src){const ib=await fetch(el.src).then(r=>r.arrayBuffer());const emb=el.src.startsWith('data:image/png')?await pdfLibDoc.embedPng(ib):await pdfLibDoc.embedJpg(ib);page.drawImage(emb,{x:px,y:py,width:80*sr,height:80*sr})}}
                    else if(el.type==='highlight'||el.type==='whiteout'){const ew=(parseInt(el.element.style.width)||0)*sr;const eh=(parseInt(el.element.style.height)||0)*sr;page.drawRectangle({x:px,y:py-eh,width:ew,height:eh,color:el.type==='whiteout'?PDFLib.rgb(1,1,1):PDFLib.rgb(1,1,0),opacity:el.type==='whiteout'?1:highlightOpacity})}
                }
                const nb=await pdfLibDoc.save();saveAs(new Blob([nb],{type:'application/pdf'}),'edited.pdf');
                hideProcessing();showToast('PDF saved! 🎉');
            }catch(err){hideProcessing();showToast('Error: '+err.message,'error')}
        }

        function showToast(msg,type='success'){const t=document.createElement('div');t.className='toast'+(type==='error'?' toast-error':'');t.textContent=msg;document.body.appendChild(t);setTimeout(()=>{t.style.opacity='0';t.style.transition='opacity 0.3s';setTimeout(()=>t.remove(),300)},2500)}
        function showProcessing(text){document.getElementById('procText').textContent=text;document.getElementById('procOverlay').classList.add('show')}
        function hideProcessing(){document.getElementById('procOverlay').classList.remove('show')}

        updateRightPanel();
        if('serviceWorker' in navigator){navigator.serviceWorker.register('../../../service-worker.js').catch(()=>{})}
    </script>
