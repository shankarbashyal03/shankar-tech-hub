<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="theme-color" content="#0f172a">
    <meta name="description" content="PDF Editor is an all-in-one solution for viewing, editing, annotating, and managing PDF documents. Easily modify text, add images, highlight content, sign forms, merge files, and convert documents with a simple and intuitive interface.">
    <title>PDF Editor | ShankarTech Hub</title>
    <link rel="icon" type="image/png" href="../../icons/logo.png">
    <link rel="apple-touch-icon" href="../../icons/logo.png">
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
    <script src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/FileSaver.js/2.0.5/FileSaver.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root{
            --bg:#0f172a;--card:#1e293b;--card-alt:#334155;--text:#f1f5f9;
            --text-secondary:#94a3b8;--accent:#3b82f6;--accent-hover:#2563eb;
            --accent2:#10b981;--danger:#ef4444;--warning:#f59e0b;--purple:#8b5cf6;
            --border:#334155;--shadow:0 8px 30px rgba(0,0,0,0.3);
            --transition:all 0.35s cubic-bezier(0.4,0,0.2,1);
            --editor-bg:#525659;
            --gradient:linear-gradient(135deg,#3b82f6 0%,#8b5cf6 100%);
        }
        body.light-mode{
            --bg:#f8fafc;--card:#ffffff;--card-alt:#f1f5f9;--text:#1e293b;
            --text-secondary:#475569;--border:#e2e8f0;
            --shadow:0 8px 30px rgba(0,0,0,0.06);--editor-bg:#e5e7eb;
        }
        *{margin:0;padding:0;box-sizing:border-box}
        body{
            font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);
            min-height:100vh;display:flex;flex-direction:column;
            transition:background 0.3s,color 0.3s;overflow-x:hidden;
        }
        h1,h2,h3{font-family:'Poppins',sans-serif;font-weight:700;line-height:1.2}
        a{text-decoration:none;color:inherit}

        /* ── TOP BAR ── */
        .top-bar{
            background:#0f172a;padding:12px 24px;display:flex;align-items:center;
            gap:12px;border-bottom:1px solid #334155;z-index:200;
        }
        body.light-mode .top-bar{background:#1e293b}
        .back-btn{
            background:rgba(255,255,255,0.08);color:#f1f5f9;border:1px solid rgba(255,255,255,0.12);
            border-radius:10px;padding:9px 16px;font-size:0.88rem;font-weight:500;
            cursor:pointer;display:flex;align-items:center;gap:7px;
            text-decoration:none;transition:all 0.3s;white-space:nowrap;
        }
        .back-btn:hover{background:rgba(255,255,255,0.14);transform:translateY(-1px)}
        .top-bar .brand{
            display:flex;align-items:center;gap:8px;margin-left:auto;
        }
        .top-bar .brand img{width:28px;height:28px;border-radius:6px}
        .top-bar .brand span{color:#3b82f6;font-weight:700;font-size:0.95rem}

        /* ── LANDING PAGE ── */
        .landing-page{
            flex:1;display:flex;align-items:center;justify-content:center;
            padding:50px 24px;
            background:radial-gradient(ellipse at top right,rgba(59,130,246,0.08) 0%,transparent 50%),
                       radial-gradient(ellipse at bottom left,rgba(139,92,246,0.05) 0%,transparent 50%),
                       radial-gradient(ellipse at center,rgba(16,185,129,0.03) 0%,transparent 70%);
        }
        .landing-container{max-width:850px;width:100%}

        .hero-header{text-align:center;margin-bottom:40px}
        .hero-badge{
            display:inline-flex;align-items:center;gap:8px;
            background:rgba(59,130,246,0.12);color:var(--accent);
            padding:8px 20px;border-radius:50px;font-weight:600;
            font-size:0.85rem;margin-bottom:20px;letter-spacing:0.3px;
            border:1px solid rgba(59,130,246,0.2);
        }
        .hero-header h1{font-size:clamp(2rem,4.5vw,3rem);font-weight:800;margin-bottom:14px;letter-spacing:-0.5px}
        .hero-header h1 .blue{background:var(--gradient);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
        .hero-header p{font-size:1.05rem;color:var(--text-secondary);max-width:620px;margin:0 auto;line-height:1.7;font-weight:400}

        .upload-card{
            background:var(--card);border:2.5px dashed var(--border);
            border-radius:24px;padding:55px 35px;text-align:center;
            cursor:pointer;transition:all 0.4s;position:relative;overflow:hidden;margin-bottom:28px;
        }
        .upload-card::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at center,rgba(59,130,246,0.06),transparent 70%);opacity:0;transition:opacity 0.4s}
        .upload-card:hover::before{opacity:1}
        .upload-card:hover{border-color:var(--accent);transform:translateY(-4px);box-shadow:0 20px 50px rgba(0,0,0,0.25)}
        .upload-card.drag-over{border-color:var(--accent2);background:rgba(16,185,129,0.04);transform:scale(1.02)}
        .upload-icon-wrap{
            width:100px;height:100px;border-radius:50%;background:var(--gradient);
            display:flex;align-items:center;justify-content:center;
            margin:0 auto 22px;font-size:2.5rem;color:#fff;
            box-shadow:0 12px 35px rgba(59,130,246,0.35);
            animation:floatIcon 3s ease-in-out infinite;
        }
        @keyframes floatIcon{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
        .upload-card h2{font-size:1.5rem;font-weight:700;margin-bottom:6px}
        .upload-card .upload-sub{color:var(--text-secondary);font-size:0.9rem;margin-bottom:12px}
        .upload-card .format-badge{display:inline-block;background:var(--card-alt);padding:6px 16px;border-radius:20px;font-size:0.78rem;color:var(--text-secondary);border:1px solid var(--border)}

        .file-loaded{
            display:none;background:var(--card);border:2px solid var(--accent2);
            border-radius:20px;padding:24px 28px;text-align:center;
            margin-bottom:20px;animation:fadeInUp 0.4s ease;
        }
        .file-loaded.show{display:block}
        .file-loaded .file-icon{font-size:3rem;color:var(--accent2);margin-bottom:8px}
        .file-loaded .fname{font-weight:700;font-size:1.05rem;color:var(--text);margin-bottom:3px;word-break:break-all}
        .file-loaded .fmeta{color:var(--text-secondary);font-size:0.82rem;margin-bottom:16px}
        .file-loaded .btns{display:flex;gap:10px;justify-content:center;flex-wrap:wrap}
        .btn{padding:12px 24px;border-radius:12px;font-weight:600;font-size:0.9rem;cursor:pointer;transition:all 0.3s;border:none;display:inline-flex;align-items:center;gap:8px;font-family:'Poppins',sans-serif}
        .btn-primary{background:var(--accent);color:#fff}.btn-primary:hover{background:var(--accent-hover);transform:translateY(-2px);box-shadow:0 8px 25px rgba(59,130,246,0.3)}
        .btn-outline{background:transparent;color:var(--text);border:1.5px solid var(--border)}.btn-outline:hover{border-color:var(--accent);color:var(--accent);transform:translateY(-2px)}
        @keyframes fadeInUp{from{opacity:0;transform:translateY(15px)}to{opacity:1;transform:translateY(0)}}

        .features-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px;margin-bottom:32px}
        .feature-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:18px 14px;text-align:center;transition:all 0.3s;cursor:default}
        .feature-card:hover{transform:translateY(-3px);border-color:var(--accent);box-shadow:0 8px 25px rgba(0,0,0,0.2)}
        .ficon{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;margin:0 auto 10px}
        .ficon.blue{background:rgba(59,130,246,0.15);color:var(--accent)}
        .ficon.green{background:rgba(16,185,129,0.15);color:var(--accent2)}
        .ficon.orange{background:rgba(245,158,11,0.15);color:var(--warning)}
        .ficon.purple{background:rgba(139,92,246,0.15);color:var(--purple)}
        .ficon.red{background:rgba(239,68,68,0.15);color:var(--danger)}
        .feature-card h4{font-size:0.85rem;font-weight:600;margin-bottom:3px}
        .feature-card p{font-size:0.73rem;color:var(--text-secondary);line-height:1.4}

        .trust-bar{display:flex;gap:20px;flex-wrap:wrap;justify-content:center;font-size:0.8rem;color:var(--text-secondary)}
        .trust-bar span{display:flex;align-items:center;gap:6px;background:var(--card);padding:8px 16px;border-radius:25px;border:1px solid var(--border)}
        .trust-bar span i{color:var(--accent2);font-size:0.75rem}

        /* ── EDITOR ── */
        .editor-full{display:none;flex:1;flex-direction:column;overflow:hidden}.editor-full.show{display:flex}
        .toolbar{height:48px;background:var(--card);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:2px;padding:0 8px;flex-shrink:0;overflow-x:auto}
        .tbtn{width:34px;height:34px;border:1.5px solid transparent;background:transparent;border-radius:7px;cursor:pointer;font-size:0.8rem;display:flex;align-items:center;justify-content:center;transition:all 0.2s;color:var(--text);flex-shrink:0}
        .tbtn:hover{background:var(--card-alt);border-color:var(--border)}.tbtn.active{background:rgba(59,130,246,0.15);border-color:var(--accent);color:var(--accent)}
        .tdv{width:1px;height:20px;background:var(--border);margin:0 2px;flex-shrink:0}
        .zdisp{min-width:40px;text-align:center;font-size:0.76rem;font-weight:600}.pnav{font-size:0.76rem;min-width:60px;text-align:center}
        .sflex{flex:1}
        .svbtn{background:var(--accent);color:#fff;padding:6px 12px;border-radius:7px;border:none;font-size:0.78rem;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:5px;transition:all 0.3s;white-space:nowrap}.svbtn:hover{background:var(--accent-hover);transform:translateY(-1px)}
        .main-area{display:flex;flex:1;overflow:hidden}
        .side-l{width:160px;background:var(--card);border-right:1px solid var(--border);overflow-y:auto;padding:8px 5px;flex-shrink:0}
        .side-l .stitle{font-size:0.68rem;font-weight:700;color:var(--text-secondary);text-transform:uppercase;letter-spacing:1px;padding:2px 4px 8px}
        .pthumb{border:2px solid var(--border);border-radius:5px;cursor:pointer;margin-bottom:5px;text-align:center;background:#fff;padding:2px;transition:all 0.2s}
        .pthumb:hover{border-color:var(--accent)}.pthumb.active{border-color:var(--accent);box-shadow:0 0 8px rgba(59,130,246,0.3)}
        .pthumb canvas{display:block;width:100%;height:auto}.pnum{font-size:0.58rem;color:var(--text-secondary)}
        .center-p{flex:1;overflow-y:auto;background:var(--editor-bg);display:flex;flex-direction:column;align-items:center;padding:14px;gap:10px}
        .pg-container{position:relative;background:#fff;box-shadow:0 4px 20px rgba(0,0,0,0.3)}.pdf-canvas{display:block}
        .overlay{position:absolute;top:0;left:0;width:100%;height:100%}
        .side-r{width:240px;background:var(--card);border-left:1px solid var(--border);overflow-y:auto;padding:12px;flex-shrink:0;display:none}.side-r.show{display:block}
        .side-r .ptitle{font-size:0.88rem;font-weight:700;color:var(--accent);margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid var(--border)}
        .fg{margin-bottom:9px}.fg label{display:block;font-size:0.7rem;font-weight:600;color:var(--text-secondary);margin-bottom:3px}
        .finput{width:100%;padding:5px 7px;border:1.5px solid var(--border);border-radius:5px;font-size:0.76rem;background:var(--card-alt);color:var(--text);transition:all 0.2s}.finput:focus{outline:none;border-color:var(--accent)}
        input[type="color"]{height:32px;cursor:pointer;padding:1px}
        .sbtns{display:flex;gap:3px}.sbtn{width:28px;height:28px;border:1.5px solid var(--border);background:var(--card-alt);border-radius:5px;cursor:pointer;font-weight:700;font-size:0.7rem;color:var(--text);transition:all 0.2s}.sbtn:hover{background:rgba(59,130,246,0.1);border-color:var(--accent)}.sbtn.active-style{background:var(--accent);color:#fff;border-color:var(--accent)}
        .cswatches{display:flex;gap:5px;flex-wrap:wrap}.cswatch{width:28px;height:28px;border-radius:6px;cursor:pointer;border:2px solid transparent}.cswatch:hover{transform:scale(1.15)}.cswatch.selected{border-color:var(--accent);box-shadow:0 0 6px rgba(59,130,246,0.4)}
        .stabs{display:flex;gap:2px;margin-bottom:7px}.stab{flex:1;padding:5px;background:var(--card-alt);border:1px solid var(--border);border-radius:5px;cursor:pointer;font-size:0.68rem;font-weight:600;text-align:center;color:var(--text-secondary);transition:all 0.2s}.stab.active{background:var(--accent);color:#fff;border-color:var(--accent)}
        .scontent{display:none}.scontent.active{display:block}.sigcanvas{width:100%;height:90px;background:#fff;border:1.5px solid var(--border);border-radius:6px;cursor:crosshair}
        .bsm{padding:5px 10px;border:none;border-radius:5px;font-size:0.72rem;font-weight:600;cursor:pointer;transition:all 0.2s;width:100%;margin-top:4px}.bsm-accent{background:var(--accent);color:#fff}.bsm-accent:hover{background:var(--accent-hover)}.bsm-outline{background:var(--card-alt);color:var(--text);border:1px solid var(--border)}.bsm-outline:hover{background:var(--border)}
        .pdf-element{position:absolute;cursor:move}.pdf-element.selected{outline:2px solid #3b82f6;box-shadow:0 0 8px rgba(59,130,246,0.4)}

        /* TOAST */
        .toast{position:fixed;top:20px;right:20px;background:#10b981;color:#fff;padding:12px 18px;border-radius:10px;font-weight:600;z-index:5000;animation:slideIn 0.3s ease;font-size:0.82rem;box-shadow:0 8px 24px rgba(0,0,0,0.3)}.toast-error{background:#ef4444}
        @keyframes slideIn{from{transform:translateX(100%);opacity:0}to{transform:translateX(0);opacity:1}}
        .proc-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(15,23,42,0.9);z-index:4000;display:none;align-items:center;justify-content:center;flex-direction:column;gap:10px}.proc-overlay.show{display:flex}
        .spinner{width:38px;height:38px;border:3px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin 0.8s linear infinite}@keyframes spin{to{transform:rotate(360deg)}}
        .proc-text{color:#fff;font-size:0.88rem;font-weight:500}

        /* ── FOOTER ── */
        .footer{
            background:#0f172a;color:#CBD5E1;padding:40px 24px 20px;border-top:1px solid #1e293b;margin-top:auto;
        }
        body.light-mode .footer{background:#1e293b}
        .footer-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:28px;max-width:1000px;margin:0 auto 24px}
        .footer-col .flogo{display:flex;align-items:center;gap:8px;margin-bottom:8px}
        .footer-col .flogo img{width:26px;height:26px;border-radius:5px}
        .footer-col .flogo span{font-weight:700;color:#3b82f6;font-size:1.1rem}
        .footer-col p{font-size:0.8rem;line-height:1.6;color:#94a3b8}
        .footer-col h4{color:#fff;font-size:0.85rem;margin-bottom:10px;text-transform:uppercase;letter-spacing:0.5px}
        .footer-col ul{list-style:none}.footer-col ul li{margin-bottom:5px}
        .footer-col ul li a{color:#CBD5E1;text-decoration:none;font-size:0.78rem;transition:color 0.2s;display:flex;align-items:center;gap:5px}.footer-col ul li a:hover{color:#fff}
        .footer-social{display:flex;gap:12px;margin-top:8px}
        .footer-social a{
            width:36px;height:36px;border-radius:50%;background:#334155;display:flex;
            align-items:center;justify-content:center;color:#CBD5E1;font-size:0.9rem;
            transition:all 0.3s;
        }
        .footer-social a:hover{background:var(--accent);color:#fff;transform:translateY(-3px)}
        .footer-bottom{text-align:center;padding-top:16px;border-top:1px solid #1e293b;font-size:0.73rem;color:#64748B;max-width:1000px;margin:0 auto}
        .footer-bottom strong{color:#3b82f6}

        @media(max-width:768px){
            .side-l{display:none}.side-r{width:100%;position:fixed;right:0;top:100px;bottom:0;z-index:150}
            .upload-card{padding:35px 20px}.upload-icon-wrap{width:75px;height:75px;font-size:1.8rem}
            .hero-header h1{font-size:1.6rem}.features-grid{grid-template-columns:repeat(2,1fr)}
        }
    </style>
</head>
<body>

    <!-- ── TOP BAR ── -->
    <div class="top-bar">
        <a href="../../index.html" class="back-btn"><i class="fas fa-arrow-left"></i> Back</a>
        <div class="brand">
            <img src="../../icons/logo.png" alt="Logo" onerror="this.style.display='none'">
            <span>ShankarTech Hub</span>
        </div>
    </div>

    <!-- ── LANDING PAGE ── -->
    <div class="landing-page" id="landingPage">
        <div class="landing-container">
            <div class="hero-header">
                <div class="hero-badge"><i class="fas fa-star"></i> All-in-One PDF Solution</div>
                <h1>Edit <span class="blue">PDF Documents</span> Like a Pro</h1>
                <p>PDF Editor is an all-in-one solution for viewing, editing, annotating, and managing PDF documents. Easily modify text, add images, highlight content, sign forms, merge files, and convert documents with a simple and intuitive interface. Whether for work, study, or personal use, PDF Editor helps you stay productive anytime, anywhere.</p>
            </div>

            <div class="upload-card" id="uploadCard" onclick="document.getElementById('fileInput').click()"
                 ondrop="handleDrop(event)" ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)">
                <div class="upload-icon-wrap"><i class="fas fa-cloud-upload-alt"></i></div>
                <h2>Drop your PDF here</h2>
                <p class="upload-sub">or click to browse your files</p>
                <span class="format-badge"><i class="fas fa-file-pdf"></i> PDF files supported • Max 100MB</span>
                <input type="file" id="fileInput" accept=".pdf" style="display:none" onchange="handleFileSelect(event)">
            </div>

            <div class="file-loaded" id="fileLoaded">
                <div class="file-icon"><i class="fas fa-file-pdf"></i></div>
                <div class="fname" id="loadedFileName"></div>
                <div class="fmeta" id="loadedFileMeta"></div>
                <div class="btns">
                    <button class="btn btn-primary" onclick="openEditor()"><i class="fas fa-edit"></i> Open in Editor</button>
                    <button class="btn btn-outline" onclick="changeFile()"><i class="fas fa-sync-alt"></i> Change File</button>
                </div>
            </div>

            <div class="features-grid">
                <div class="feature-card"><div class="ficon blue"><i class="fas fa-font"></i></div><h4>Edit Text</h4><p>Modify & add text</p></div>
                <div class="feature-card"><div class="ficon green"><i class="fas fa-image"></i></div><h4>Add Images</h4><p>Insert photos & logos</p></div>
                <div class="feature-card"><div class="ficon orange"><i class="fas fa-highlighter"></i></div><h4>Highlight</h4><p>Mark important content</p></div>
                <div class="feature-card"><div class="ficon purple"><i class="fas fa-signature"></i></div><h4>Sign Forms</h4><p>Draw & add signatures</p></div>
                <div class="feature-card"><div class="ficon red"><i class="fas fa-shield-alt"></i></div><h4>100% Private</h4><p>Files stay on device</p></div>
            </div>

            <div class="trust-bar">
                <span><i class="fas fa-check-circle"></i> No sign-up required</span>
                <span><i class="fas fa-check-circle"></i> Files never uploaded</span>
                <span><i class="fas fa-check-circle"></i> Free forever</span>
            </div>
        </div>
    </div>

    <!-- ── EDITOR ── -->
    <div class="editor-full" id="editorFull">
        <div class="toolbar">
            <button class="tbtn active" data-tool="select" title="Select"><i class="fas fa-mouse-pointer"></i></button>
            <button class="tbtn" data-tool="text" title="Add Text"><i class="fas fa-font"></i></button>
            <button class="tbtn" data-tool="image" title="Add Image"><i class="fas fa-image"></i></button>
            <button class="tbtn" data-tool="highlight" title="Highlight"><i class="fas fa-highlighter"></i></button>
            <button class="tbtn" data-tool="whiteout" title="Whiteout"><i class="fas fa-square"></i></button>
            <button class="tbtn" data-tool="sign" title="Signature"><i class="fas fa-signature"></i></button>
            <div class="tdv"></div>
            <button class="tbtn" data-tool="undo" title="Undo"><i class="fas fa-undo"></i></button>
            <button class="tbtn" data-tool="redo" title="Redo"><i class="fas fa-redo"></i></button>
            <div class="tdv"></div>
            <button class="tbtn" onclick="zoomOut()">−</button><span class="zdisp" id="zoomDisplay">100%</span><button class="tbtn" onclick="zoomIn()">+</button>
            <div class="tdv"></div>
            <button class="tbtn" onclick="prevPage()">◀</button><span class="pnav" id="pageNav">1/1</span><button class="tbtn" onclick="nextPage()">▶</button>
            <div class="sflex"></div>
            <button class="svbtn" onclick="savePDF()"><i class="fas fa-save"></i> Save PDF</button>
        </div>
        <div class="main-area">
            <div class="side-l"><div class="stitle">Pages</div><div id="thumbnails"></div></div>
            <div class="center-p" id="centerP"></div>
            <div class="side-r show" id="sideR"><div class="ptitle" id="panelTitle">Select Tool</div><div id="panelContent"><p style="color:var(--text-secondary);font-size:0.78rem;">Click element to select. Drag to move. Delete to remove.</p></div></div>
        </div>
    </div>

    <!-- PROCESSING OVERLAY -->
    <div class="proc-overlay" id="procOverlay"><div class="spinner"></div><div class="proc-text" id="procText">Processing...</div></div>

    <!-- ── FOOTER ── -->
